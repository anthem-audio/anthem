# Default text normalization for the repository.
* text=auto

# Keep engine/CMake source files on LF across platforms so clang-format checks
# behave consistently in local clones and CI.
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.cxx text eol=lf
*.h text eol=lf
*.hh text eol=lf
*.hpp text eol=lf
*.hxx text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# Keep Dart normalized in the repo, but allow checkout line endings to follow
# each developer's Git settings.
*.dart text

# Keep a few repo-authored text files on LF as well.
*.md text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.sh text eol=lf

# Windows-native scripts should keep CRLF in the working tree.
*.bat text eol=crlf
*.cmd text eol=crlf
